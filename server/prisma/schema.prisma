generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("OPERATOR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  industries          UserIndustry[]
  workOrders          WorkOrder[]
  todos               Todo[]
  importLogs          ImportLog[]
  promotionTasks      PromotionTask[]
  promotionExecutions PromotionExecution[]
}

model Industry {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  users                   UserIndustry[]
  accounts                Account[]
  dashboardData           DashboardData[]
  workOrders              WorkOrder[]
  importLogs              ImportLog[]
  promotionTaskIndustries PromotionTaskIndustry[]
}

model UserIndustry {
  id         String @id @default(cuid())
  userId     String
  industryId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([userId, industryId])
}

model Account {
  id         String   @id @default(cuid())
  wechatId   String?
  realName   String?
  phone      String?
  status     String   @default("NORMAL")
  remark     String?
  industryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  industry            Industry             @relation(fields: [industryId], references: [id])
  device              Device?
  promotionExecutions PromotionExecution[]
  touchpointData      TouchpointData[]
}

model Device {
  id        String   @id @default(cuid())
  model     String?
  imei      String?
  status    String   @default("IN_USE")
  remark    String?
  accountId String   @unique
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model DashboardData {
  id         String   @id @default(cuid())
  date       DateTime
  category   String
  metrics    String
  industryId String
  createdAt  DateTime @default(now())

  industry Industry @relation(fields: [industryId], references: [id])

  @@index([industryId, category, date])
}

model ImportLog {
  id          String   @id @default(cuid())
  fileName    String
  category    String
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  failRows    Int      @default(0)
  status      String   @default("SUCCESS")
  errors      String?
  userId      String
  industryId  String
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  industry Industry @relation(fields: [industryId], references: [id])

  @@index([industryId, category])
}

model WorkOrder {
  id          String   @id @default(cuid())
  orderNo     String   @unique
  title       String
  description String?
  type        String
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  deadline    DateTime?
  industryId  String
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  industry Industry @relation(fields: [industryId], references: [id])
  creator  User     @relation(fields: [creatorId], references: [id])

  @@index([industryId, status])
}

model Todo {
  id        String    @id @default(cuid())
  title     String
  completed Boolean   @default(false)
  dueDate   DateTime?
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromotionTask {
  id          String    @id @default(cuid())
  taskNo      String    @unique
  title       String
  description String?
  contentType String    @default("产品推广")
  status      String    @default("DRAFT")
  priority    String    @default("MEDIUM")
  deadline    DateTime?
  creatorId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator    User                      @relation(fields: [creatorId], references: [id])
  industries PromotionTaskIndustry[]
  executions PromotionExecution[]

  @@index([status])
}

model PromotionTaskIndustry {
  id         String @id @default(cuid())
  taskId     String
  industryId String

  task     PromotionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  industry Industry      @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([taskId, industryId])
}

model PromotionExecution {
  id                  String   @id @default(cuid())
  taskId              String
  operatorId          String
  accountId           String
  hasContactedManager Boolean  @default(false)
  contactNote         String?
  touchpoints         String   @default("[]")
  status              String   @default("PENDING")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  task           PromotionTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  operator       User            @relation(fields: [operatorId], references: [id])
  account        Account         @relation(fields: [accountId], references: [id])
  touchpointData TouchpointData[]

  @@index([taskId, accountId])
}

model TouchpointData {
  id          String   @id @default(cuid())
  executionId String
  accountId   String
  touchpoint  String
  metrics     String   @default("{}")
  executeDate DateTime
  remark      String?
  createdAt   DateTime @default(now())

  execution PromotionExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  account   Account            @relation(fields: [accountId], references: [id])

  @@index([executionId, touchpoint])
  @@index([accountId, touchpoint])
}
