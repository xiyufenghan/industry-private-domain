{
  "name": "super-form",
  "version": "1.0.0",
  "description": "超级表单 - 支持OCR、自动回收、数据追踪、腾讯文档输出",
  "private": true,
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch"
  },
  "browserslist": [
    "last 3 Chrome versions",
    "last 3 Firefox versions",
    "last 3 Opera versions",
    "last 3 Safari versions",
    "last 3 Edge versions",
    "Firefox ESR",
    "ie >= 9",
    "iOS >= 9",
    "Android >= 5"
  ],
  "dependencies": {
    "@nutui/nutui-react-taro": "^2.6.0",
    "@tarojs/components": "4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "dayjs": "^1.11.10",
    "immer": "^10.0.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@tarojs/cli": "4.1.11",
    "@tarojs/plugin-framework-react": "^4.1.11",
    "@tarojs/webpack5-runner": "4.1.11",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "babel-preset-taro": "4.1.11",
    "sass": "^1.26.0",
    "typescript": "^5.0.0"
  }
}
